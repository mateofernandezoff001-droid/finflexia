# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
JWT_SECRET="FINFLEX_PROFESSIONAL_SECRET"

# SUPABASE CONFIGURATION
# Required for Netlify + Supabase migration
VITE_SUPABASE_URL="https://cuxvmggjwcvustrxwume.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_t81LFsAWbQKbOxxs0SldGg_IyysnmNQ"

# DATABASE CONFIGURATION
# Set DATABASE_URL to use PostgreSQL (e.g. Supabase). 
# If not set, the app will fall back to SQLite for local development.
DATABASE_URL="postgres://user:password@host:port/dbname"

# SECURITY CONFIGURATION
NODE_ENV="production"
PORT=3000
CORS_ALLOWED_ORIGINS="https://finflex.vercel.app,https://finflex.com"

# EMAIL CONFIGURATION (Nodemailer)
SMTP_HOST="smtp.provider.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="FinFlex <no-reply@finflex.com>"
