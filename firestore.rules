rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Phase 4: Entity Validations
    // -------------------------------------------------------------------------

    // User Validation
    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && data.email is string && data.email.size() > 0 && data.email.size() < 255
        && data.role in ['user', 'admin']
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100))
        && data.keys().hasAll(['userId', 'email', 'role']);
    }

    // Wallet Validation
    function isValidWallet(data) {
      return data.userId == request.auth.uid
        && data.balance is number
        && data.currency is string && data.currency.size() == 3
        && data.keys().hasAll(['userId', 'balance', 'currency']);
    }

    // Transaction Validation
    function isValidTransaction(data) {
      return data.userId == request.auth.uid
        && data.type in ['income', 'expense', 'transfer', 'investment']
        && data.amount is number && data.amount != 0
        && data.timestamp == request.time
        && data.keys().hasAll(['userId', 'type', 'amount', 'timestamp']);
    }

    // Portfolio Validation
    function isValidPortfolio(data) {
      return data.userId == request.auth.uid
        && data.totalValue is number
        && data.keys().hasAll(['userId', 'totalValue']);
    }

    // Insight Validation
    function isValidInsight(data) {
      return data.userId == request.auth.uid
        && data.insight is string && data.insight.size() < 5000
        && data.timestamp == request.time
        && data.keys().hasAll(['userId', 'insight', 'timestamp']);
    }

    // -------------------------------------------------------------------------
    // Collection Match Blocks
    // -------------------------------------------------------------------------

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().role == existing().role; // Immutable role
    }

    // Wallets
    match /users/{userId}/wallets/{walletId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidWallet(incoming()) && isValidId(walletId);
      allow update: if isOwner(userId) && isValidWallet(incoming())
        && incoming().userId == existing().userId;
    }

    // Transactions
    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidTransaction(incoming()) && isValidId(transactionId);
      // Transactions are typically immutable after creation for audit purposes
      allow update, delete: if false;
    }

    // Portfolios
    match /users/{userId}/portfolios/{portfolioId} {
      allow list, get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidPortfolio(incoming());
    }

    // Insights
    match /users/{userId}/insights/{insightId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidInsight(incoming());
      allow update, delete: if false;
    }
  }
}
